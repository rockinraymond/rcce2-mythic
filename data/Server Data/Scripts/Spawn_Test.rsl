Using "RC_Core.rcm"
; Define entry function 'Main'

Function Main()

giveitem(actor(),"dagger",1)
giveitem(actor(),"hand axe",1)
giveitem(actor(),"battle axe",1)
giveitem(actor(),"great axe",1)
giveitem(actor(),"short bow",1)
giveitem(actor(),"long bow",1)
giveitem(actor(),"dagger",1)
giveitem(actor(),"short sword",1)
giveitem(actor(),"long sword",1)
giveitem(actor(),"scimitar",1)
giveitem(actor(),"two handed sword",1)
giveitem(actor(),"warhammer",1)
giveitem(actor(),"mace",1)
giveitem(actor(),"maul",1)
giveitem(actor(),"cudgel",1)
giveitem(actor(),"walking staff",1)
giveitem(actor(),"quarterstaff",1)
giveitem(actor(),"pole arm",1)
giveitem(actor(),"spear",1)

NPC = Actor()

SetName(NPC, "Earl")
SetTag(NPC, "Weapon Merchant")



End Function