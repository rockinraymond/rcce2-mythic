case 9
return 4
case 10
return 4
default
return 0
End Select
End Function

Function FindAttackBonus(playerClass$, playerLevel%)
Select playerClass$
    case "Magic User"
        return AttackBonusMagicUser(playerLevel%)
    case "Thief"
        return AttackBonusThiefCleric(playerLevel%)
    case "Cleric"
        return AttackBonusThiefCleric(playerLevel%)
    default
        return AttackBonusFighter(playerLevel%)
End Select
End Function