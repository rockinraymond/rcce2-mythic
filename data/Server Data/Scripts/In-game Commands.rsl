Function Posi()
	Output(Actor(), ActorX(Actor()) + " " +  ActorY(Actor()) +" " + ActorZ(Actor()))
End Function

function setPassive()
	Target = CONTEXTACTOR()
	ACTORAGGRESSIVENESS(Target, 1, 0)
End Function

function setDefensive()
	Target = CONTEXTACTOR()
	ACTORAGGRESSIVENESS(Target, 1, 1)
End Function

function setAggresive()
	Target = CONTEXTACTOR()
	ACTORAGGRESSIVENESS(Target, 1, 2)
End Function

function setNonCombat()
	Target = CONTEXTACTOR()
	ACTORAGGRESSIVENESS(Target, 1, 3)
End Function

function resetCasting()
	DeleteActorEffect(Actor(), "Casting")
End Function