Using "RC_Core.rcm"
; Quest: Raiders at the Gate
; A town captain asks the player to cull the Orc Raiders menacing the wilds.
; Kill 3 Orc/Raider, then return for gold, XP and an Imperial Helmet.
;
; Structure mirrors the shipped Ratcatcher1.rsl state machine (resumes across
; right-clicks via QuestStatus), but rewards items that actually exist in the
; catalog. Reward BVMs are privileged -> this script is on Privileged Scripts.dat.

Function Main()

	Player = Actor()
	PlayerName$ = Name(Player)
	Target = ContextActor()
	TargetName$ = Name(Target)
	Persistent(1)

	QuestName$ = "Raiders at the Gate"
	QuestResults$ = QuestStatus(Player, QuestName)
	QuestReturn$ = "Return to " + TargetName + " to claim your reward."

	WaitRace$ = "Orc"
	WaitClass$ = "Raider"
	ID = ActorID(WaitRace$, WaitClass$)

	RewardMoney = 150
	RewardXp = 120
	RewardItem$ = "Imperial Helmet"
	RewardItemQuantity = 1

	Step3$ = "Slay 3 Orc Raiders"
	Step2$ = "Slay 2 more Orc Raiders"
	Step1$ = "Slay 1 more Orc Raider"

	D = OpenDialog(Player, Target, TargetName, 65535, 0.25, 0.05, 0.42, 0.65)
	DialogOutput(Player, D, "Well met, " + PlayerName + ".", 255, 255, 255)
	DoEvents(800)

	If QuestResults = ""
		DialogOutput(Player, D, "Orc raiders have been harrying travellers beyond the gate.", 255, 255, 255)
		DialogOutput(Player, D, "Cut down three of them and I'll see you well rewarded. Will you do it?", 255, 255, 255)
		Result = DialogInput(Player, D, "Accept the hunt|Not right now", "|")
		If Result = 1
			NewQuest(Player, QuestName, Step3, 200, 90, 60)
			Output(Player, QuestName + ": " + Step3, 255, 255, 255)
			CloseDialog(Player, D)
			WaitKill(Player, ID, 1)
			UpdateQuest(Player, QuestName, Step2, 200, 90, 60)
			WaitKill(Player, ID, 1)
			UpdateQuest(Player, QuestName, Step1, 200, 90, 60)
			WaitKill(Player, ID, 1)
			UpdateQuest(Player, QuestName, QuestReturn, 60, 200, 90)
			Output(Player, QuestName + ": " + QuestReturn, 255, 255, 255)
		Else
			CloseDialog(Player, D)
		EndIf

	ElseIf QuestResults = Step3
		DialogOutput(Player, D, "The raiders still stand. Three of them must fall.", 255, 255, 255)
		DialogInput(Player, D, "Goodbye")
		CloseDialog(Player, D)
		WaitKill(Player, ID, 1)
		UpdateQuest(Player, QuestName, Step2, 200, 90, 60)
		WaitKill(Player, ID, 1)
		UpdateQuest(Player, QuestName, Step1, 200, 90, 60)
		WaitKill(Player, ID, 1)
		UpdateQuest(Player, QuestName, QuestReturn, 60, 200, 90)

	ElseIf QuestResults = Step2
		DialogOutput(Player, D, "Two raiders yet draw breath.", 255, 255, 255)
		DialogInput(Player, D, "Goodbye")
		CloseDialog(Player, D)
		WaitKill(Player, ID, 1)
		UpdateQuest(Player, QuestName, Step1, 200, 90, 60)
		WaitKill(Player, ID, 1)
		UpdateQuest(Player, QuestName, QuestReturn, 60, 200, 90)

	ElseIf QuestResults = Step1
		DialogOutput(Player, D, "One raider remains. Finish the work.", 255, 255, 255)
		DialogInput(Player, D, "Goodbye")
		CloseDialog(Player, D)
		WaitKill(Player, ID, 1)
		UpdateQuest(Player, QuestName, QuestReturn, 60, 200, 90)

	ElseIf QuestResults = QuestReturn
		DialogOutput(Player, D, "The gate is safe again. You have my thanks, " + PlayerName + ".", 255, 255, 255)
		DialogInput(Player, D, "Goodbye")
		CompleteQuest(Player, QuestName)
		GiveItem(Player, RewardItem, RewardItemQuantity)
		GiveXp(Player, RewardXp)
		ChangeGold(Player, RewardMoney)
		Output(Player, "Reward: " + RewardItem + ", " + RewardMoney + " gold and " + RewardXp + " xp.", 60, 200, 90)
		CloseDialog(Player, D)

	ElseIf QuestComplete(Player, QuestName) = 1
		DialogOutput(Player, D, "The raiders are routed. Rest easy, friend.", 255, 255, 255)
		DialogInput(Player, D, "Goodbye")
		CloseDialog(Player, D)

	Else
		DialogOutput(Player, D, "Your hunt is unfinished: " + QuestResults, 255, 255, 255)
		DialogInput(Player, D, "Goodbye")
		CloseDialog(Player, D)
	EndIf

	Return

End Function

Function Examine()

	Output(Actor(), "The town Captain, hard-eyed from years at the gate. He has work for a willing blade.")

End Function
