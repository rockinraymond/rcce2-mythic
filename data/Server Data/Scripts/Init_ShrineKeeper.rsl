Using "RC_Core.rcm"
; Spawn-init for the Shrine Keeper (Northern Shrine). Names the NPC properly —
; its spawn previously ran the leftover Spawn_Test init, which named it "Test Human".
; Runs once at spawn (the spawn's `script` slot). SetName is privileged -> allowlisted.

Function Main()

	NPC = Actor()
	SetName(NPC, "Shrine Keeper")

	Return

End Function
