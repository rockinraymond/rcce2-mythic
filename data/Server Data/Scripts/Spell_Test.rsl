Using "RC_Core.rcm"


function setPassive()
	Target = ContextActor()
	ACTORAGGRESSIVENESS(Target, 1, 0)
End Function

function setDefensive()
	Target = ContextActor()
	ACTORAGGRESSIVENESS(Target, 1, 1)
End Function

function setAggresive()
	Target = ContextActor()
	ACTORAGGRESSIVENESS(Target, 1, 2)
End Function

function setNonCombat()
	Target = ContextActor()
	ACTORAGGRESSIVENESS(Target, 1, 3)
End Function

function recruit()
	Player = Actor()
	Target = ContextActor()
	SetLeader(Target, Player)
End Function
