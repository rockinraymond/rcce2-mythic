Using "RC_Core.rcm"

; Class based functions for leveling up used in levelup.rsl

Function LevelFighter(Player,NewLevel)
PlayerCon = Attribute(player,"constitution")

;IncreaseAttackBonus
ATKBNS% = AttackBonusFighter(NewLevel)
SetAttribute(Player, "Attack Bonus", ATKBNS%)
;Increase Health
HitDie = 8

If Race(Player) = "Elf" OR Race(Player) = "Halfling"
HitDie = 6
EndIf

FlatRate = 2
CurrentHealth = MaxAttribute(Player,"Health")

If (NewLevel < 10)
HealthIncrease = Rand(1,HitDie) + AbilityBonus(PlayerCon)
	If (HealthIncrease < 1)
	HealthIncrease = 1
	EndIf
Else
HealthIncrease = FlatRate
EndIf

Output(Player,"You have gained " + HealthIncrease + " hitpoints!", 150,255,150)
NewHealth = CurrentHealth + HealthIncrease
SetMaxAttribute(Player,"Health",NewHealth)
SetAttribute(Player,"Health", NewHealth)
Return

End Function

Function LevelThief(Player,NewLevel)
PlayerCon = Attribute(player,"constitution")

;IncreaseAttackBonus
ATKBNS = AttackBonusThiefCleric(NewLevel)
SetAttribute(Player, "Attack Bonus", ATKBNS)

;Increase Health
HitDie = 4
FlatRate = 2
CurrentHealth = MaxAttribute(Player,"Health")

If (NewLevel < 10)
HealthIncrease = Rand(1,HitDie) + AbilityBonus(PlayerCon)
	If (HealthIncrease < 1)
	HealthIncrease = 1
	EndIf
Else
HealthIncrease = FlatRate
EndIf
Output(Player,"You have gained " + HealthIncrease + " hitpoints!", 150,255,150)
NewHealth = CurrentHealth + HealthIncrease
SetMaxAttribute(Player,"Health",NewHealth)
SetAttribute(Player,"Health", NewHealth)
Return
End Function

Function LevelCleric(Player,NewLevel)
