Function AbilityBonus(SkillLevel%)
Select SkillLevel
case 3
return -3
case 4
return -2
case 5
return -2
case 6
return -1
case 7 
return -1
case 8
return -1
case 13 OR 14 OR 15
return 1
case 14
return 1
case 15
return 1
case 16
return 2
case 17
return 2
case 18
return 3
default 
return 0
End Select

End Function

