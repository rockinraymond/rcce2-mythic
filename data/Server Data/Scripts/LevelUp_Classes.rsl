Function DeLevelFighter(Player,NewLevel)

;DecreaseAttackBonus
ATKBNS% = AttackBonusFighter(NewLevel)
SetAttribute(Player, "Attack Bonus", ATKBNS%)
;Decrease Health
HitDie = 8

If Race(Player) = "Elf" OR Race(Player) = "Halfling"
HitDie = 6
EndIf

FlatRate = 2
CurrentHealth = MaxAttribute(Player,"Health")

If (NewLevel < 10)
HealthDecrease = Rand(1,HitDie)
Else
HealthDecrease = FlatRate
EndIf

Output(Player,"You have lost " + HealthDecrease + " hitpoints!", 255,150,150)
NewHealth = CurrentHealth - HealthDecrease
If newhealth < hitdie
newhealth = hitdie
EndIf
SetMaxAttribute(Player,"Health",NewHealth)
If Attribute(player,Health) > MaxAttribute(Player,"health")
SetAttribute(Player,"Health", NewHealth)
EndIf
Return

End Function

