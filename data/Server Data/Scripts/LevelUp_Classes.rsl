Function AttackBonusFighter(newLevel%)

Select newLevel
case 1
return 1
case 2
return 2
case 3
return 2
case 4
return 3
case 5
return 4
case 6
return 4
case 7
return 5
case 8
return 6
case 9
return 6
case 10
return 6
default
return 0
End Select

return 0
End Function

