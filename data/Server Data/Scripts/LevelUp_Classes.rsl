Function NextLvlXPFighter(PlayerLevel%)
Select PlayerLevel
case 1
XPAMT = 2000
case 2
XPAMT = 4000
case 3
XPAMT = 8000
case 4
XPAMT = 16000
case 5
XPAMT = 32000
case 6
XPAMT = 64000
case 7
XPAMT = 120000
case 8
XPAMT = 240000
case 9
XPAMT = 360000
default
XPAMT = 0
End Select
Return XPAMT
End Function

