Using "RC_Core.rcm"
; Default player login script
; You may alter this script however you like

; The entry function for this script is always "Main"
; There is no context actor for this script
Function Main()

Player = Actor()

If Attribute(Player,"Health") = 0
    ; Restore some health and take away xp
		SetAttribute(Player, "Health", 1)
		; Warp back to area start
		Warp(Player, ActorZone(Player), "Start")
EndIf


End Function
