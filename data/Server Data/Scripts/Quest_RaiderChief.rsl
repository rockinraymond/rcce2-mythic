Using "RC_Core.rcm"
; Quest: The Raider-Chief
; A Wounded Scout (wilds) asks the player to avenge the slaughtered patrol by slaying
; Grukk, the Raider-Chief (the Orc/Warlord mini-boss deep in the Test Zone). A single
; kill; rewards gold, XP, and the Imperial Armor breastplate (completing the Imperial
; set with the Helmet from "Raiders at the Gate").
;
; Single-target version of the shipped Quest_OrcRaiders.rsl state machine (resumes
; across right-clicks via QuestStatus). Reward BVMs are privileged -> allowlisted.

Function Main()

	Player = Actor()
	PlayerName$ = Name(Player)
	Target = ContextActor()
	TargetName$ = Name(Target)
	Persistent(1)

	QuestName$ = "The Raider-Chief"
	QuestResults$ = QuestStatus(Player, QuestName)
	QuestReturn$ = "Return to the scout - Grukk is slain."

	WaitRace$ = "Orc"
	WaitClass$ = "Warlord"
	ID = ActorID(WaitRace$, WaitClass$)

	RewardMoney = 200
	RewardXp = 150
	RewardItem$ = "Imperial Armor"
	RewardItemQuantity = 1

	Step1$ = "Slay Grukk, the Raider-Chief"

	D = OpenDialog(Player, Target, TargetName, 65535, 0.25, 0.05, 0.42, 0.65)
	DialogOutput(Player, D, "You have the look of a fighter, " + PlayerName + ".", 255, 255, 255)
	DoEvents(800)

	If QuestResults = ""
		DialogOutput(Player, D, "Grukk, the Raider-Chief, led the warband that butchered my patrol.", 255, 255, 255)
		DialogOutput(Player, D, "He lairs deep in these wilds. Cut him down and the raids will falter.", 255, 255, 255)
		Result = DialogInput(Player, D, "Avenge the patrol|Not yet", "|")
		If Result = 1
			NewQuest(Player, QuestName, Step1, 200, 90, 60)
			Output(Player, QuestName + ": " + Step1, 255, 255, 255)
			CloseDialog(Player, D)
			WaitKill(Player, ID, 1)
			UpdateQuest(Player, QuestName, QuestReturn, 60, 200, 90)
			Output(Player, QuestName + ": " + QuestReturn, 60, 200, 90)
		Else
			CloseDialog(Player, D)
		EndIf

	ElseIf QuestResults = Step1
		DialogOutput(Player, D, "Grukk still draws breath. Find him deep in the wilds.", 255, 255, 255)
		DialogInput(Player, D, "Goodbye")
		CloseDialog(Player, D)
		WaitKill(Player, ID, 1)
		UpdateQuest(Player, QuestName, QuestReturn, 60, 200, 90)

	ElseIf QuestResults = QuestReturn
		DialogOutput(Player, D, "The Chief is dead. The patrol is avenged - take this, you have earned it.", 255, 255, 255)
		DialogInput(Player, D, "Goodbye")
		CompleteQuest(Player, QuestName)
		GiveItem(Player, RewardItem, RewardItemQuantity)
		GiveXp(Player, RewardXp)
		ChangeGold(Player, RewardMoney)
		Output(Player, "Reward: " + RewardItem + ", " + RewardMoney + " gold and " + RewardXp + " xp.", 60, 200, 90)
		CloseDialog(Player, D)

	ElseIf QuestComplete(Player, QuestName) = 1
		DialogOutput(Player, D, "Grukk is dead and the wilds are quieter. My thanks, " + PlayerName + ".", 255, 255, 255)
		DialogInput(Player, D, "Goodbye")
		CloseDialog(Player, D)

	Else
		DialogOutput(Player, D, "Your hunt is unfinished: " + QuestResults, 255, 255, 255)
		DialogInput(Player, D, "Goodbye")
		CloseDialog(Player, D)
	EndIf

	Return

End Function

Function Examine()

	Output(Actor(), "A wounded scout, grim with purpose - he hungers to see Grukk the Raider-Chief dead.")

End Function
